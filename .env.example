# Copy this file to .env and fill in values before running locally.
# NEVER commit .env to git.

# Required for key persistence across restarts.
# Generate with:  python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
# Or just start the server once without it set — it will print the seed to stdout.
PRIVATE_KEY_SEED=

# Optional: raises GitHub API rate limit from 60 → 5000 req/hour.
# Create a fine-grained PAT at https://github.com/settings/tokens
GITHUB_TOKEN=
